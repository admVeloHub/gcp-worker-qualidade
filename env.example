# VERSION: v1.4.2 | DATE: 2026-06-05 | AUTHOR: VeloHub Development Team
# CHANGELOG: v1.4.2 - GEMINI_AUDIO_TIMEOUT_MS (default 10 min)
# CHANGELOG: v1.4.1 - Porta local: WORKER na FONTE DA VERDADE/.env (não PORT no subprojeto)
# CHANGELOG: v1.4.0 - Heartbeat interno, fila serial, espera GCS (sem Cloud Scheduler)
# CHANGELOG: v1.3.0 - Gemini Enterprise ADC; GPT RAG obrigatório; vector stores; remove ENABLE_GPT_ANALYSIS
# CHANGELOG: v1.2.2 - PENDING_WORK_ACTIVE_MS, BACKLOG_IMMEDIATE, SWEEP_DIRECT_PROCESS
# Configurações do Worker de Processamento de Áudio
#
# IMPORTANTE: Todas as credenciais e chaves de API devem ser armazenadas no GCP Secret Manager
# Os nomes dos secrets devem corresponder exatamente aos valores abaixo

# Google Cloud Platform Configuration
GCP_PROJECT_ID=velohub-471220
GOOGLE_CLOUD_LOCATION=global
GCP_LOCATION=us-central1

# Google Cloud Storage Bucket Name
GCS_BUCKET_NAME=qualidade_audio_envio

# Pub/Sub Configuration
PUBSUB_TOPIC_NAME=qualidade_audio_envio
PUBSUB_SUBSCRIPTION_NAME=upload_audio_qualidade

# MongoDB Configuration
CONSOLE_ANALISES_DB=console_analises

# Gemini Enterprise (produção: ADC na conta de serviço Cloud Run — sem chave AI Studio no container)
GEMINI_MODEL_ID=gemini-3.5-flash
# Timeout da chamada multimodal (ligações longas podem levar vários minutos)
GEMINI_AUDIO_TIMEOUT_MS=600000

# Worker Configuration
BACKEND_API_URL=https://backend-gcp-278491073220.us-east1.run.app

MAX_RETRIES=3

PENDING_WORK_ACTIVE_MS=15000
BACKLOG_IMMEDIATE=true
SWEEP_DIRECT_PROCESS=true

# Autonomia do worker (sem observatório / Cloud Scheduler)
WORKER_HEARTBEAT_MS=30000
TASK_GAP_MS=1000
GCS_READY_MAX_WAIT_MS=45000
GCS_READY_POLL_MS=1000

# Cloud Run: PORT=8080 (definido no deploy). Local: use WORKER na FONTE DA VERDADE/.env (ex.: WORKER=3002)
# PORT=8080

# OpenAI GPT — auditoria técnica com RAG (obrigatório no pipeline)
GPT_MODEL=gpt-5-mini
OPENAI_VECTOR_STORE_PUBLIC=vs_69fe281ef0f48191a5587521c18a18c1
OPENAI_VECTOR_STORE_INTERNAL=vs_6a0b05c7fe34819186e4f6dab9f1bf56
