# VERSION: v1.2.2 | DATE: 2026-06-02 | AUTHOR: VeloHub Development Team
# CHANGELOG: v1.2.2 - PENDING_WORK_ACTIVE_MS, BACKLOG_IMMEDIATE, SWEEP_DIRECT_PROCESS
# CHANGELOG: v1.2.1 - BACKEND_API_URL: esclarecido como base URL do backend Skynet (sem /api); exemplo Cloud Run
# CHANGELOG: v1.2.0 - ENABLE_GPT_ANALYSIS: documentação alinhada ao padrão off por padrão (só true ativa GPT)
# Configurações do Worker de Processamento de Áudio
#
# IMPORTANTE: Todas as credenciais e chaves de API devem ser armazenadas no GCP Secret Manager
# Os nomes dos secrets devem corresponder exatamente aos valores abaixo

# Google Cloud Platform Configuration
GCP_PROJECT_ID=velohub-471220
GCP_LOCATION=us-central1

# Google Cloud Storage Bucket Name
GCS_BUCKET_NAME=qualidade_audio_envio

# Pub/Sub Configuration
PUBSUB_TOPIC_NAME=qualidade_audio_envio
PUBSUB_SUBSCRIPTION_NAME=upload_audio_qualidade

# MongoDB Configuration
# Nome do secret no Secret Manager que contém a URI de conexão MongoDB
# O worker buscará automaticamente o secret 'MONGO_ENV' do Secret Manager
CONSOLE_ANALISES_DB=console_analises

# Vertex AI Configuration
# Nome do secret no Secret Manager que contém a chave da API Gemini
# O worker buscará automaticamente o secret 'GEMINI_API_KEY' do Secret Manager
# Outros secrets disponíveis: GOOGLE_CREDENTIALS, google-client-id, google-client-secret, OPENAI_API_KEY

# Worker Configuration
# URL base do backend Skynet (Dev-SKYNET / API VeloHub em Cloud Run).
# Sem sufixo /api — o worker chama {BACKEND_API_URL}/api/audio-analise/notify-completed
# Desenvolvimento local: http://localhost:3001
BACKEND_API_URL=https://backend-gcp-278491073220.us-east1.run.app

# Máximo de tentativas de retry no processamento
MAX_RETRIES=3

# Fila ativa: loop interno (ms) enquanto houver áudio pendente no Mongo ou em processamento
PENDING_WORK_ACTIVE_MS=15000
# Drenagem no arranque: processa backlog sem abrir observatório
BACKLOG_IMMEDIATE=true
SWEEP_DIRECT_PROCESS=true

# Porta do servidor HTTP (para health check e observatório)
PORT=8080

# Análise GPT Adicional
# Habilita análise complementar com OpenAI GPT após análise Gemini (somente se =true)
# Padrão: desativado (não envia para GPT sem ENABLE_GPT_ANALYSIS=true)
ENABLE_GPT_ANALYSIS=false

# Modelo GPT a ser usado para análise
# Padrão: gpt-5-mini
GPT_MODEL=gpt-5-mini

